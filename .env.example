# PodAgent Research Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# PODCAST INDEX API (FREE)
# Get your keys at: https://api.podcastindex.org/signup
# Required for: validate_podcastindex.py, validate_combined.py
# =============================================================================
PODCAST_INDEX_API_KEY=your_podcast_index_api_key_here
PODCAST_INDEX_API_SECRET=your_podcast_index_api_secret_here

# =============================================================================
# SPOTIFY WEB API (FREE)
# Get your keys at: https://developer.spotify.com/dashboard
# Required for: validate_spotify.py, validate_combined.py
# =============================================================================
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# =============================================================================
# YOUTUBE TRANSCRIPT API
# Status: NO KEY NEEDED ✅
# The youtube-transcript-api library works without authentication
# =============================================================================
# No configuration required

# =============================================================================
# OPTIONAL: PROXY CONFIGURATION (for YouTube)
# If you encounter IP blocking from cloud providers, use a proxy
# Documentation: https://github.com/jdepoix/youtube-transcript-api#proxies
# Get free proxy at: https://www.webshare.io/
# =============================================================================

# Option 1: Webshare Proxy (Recommended)
# WEBSHARE_PROXY_USERNAME=your_webshare_username
# WEBSHARE_PROXY_PASSWORD=your_webshare_password

# Option 2: Generic HTTP/HTTPS Proxy
# HTTP_PROXY=http://user:pass@proxy:port
# HTTPS_PROXY=https://user:pass@proxy:port

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit the .env file to version control
# 2. All API keys listed here are FREE - no credit card required
# 3. Keys are only used for local validation/testing
# 4. YouTube works without any API key
# 5. Keep your .env file secure and don't share it
